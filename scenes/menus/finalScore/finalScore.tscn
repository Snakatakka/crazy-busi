[sub_resource type="GDScript" id="GDScript_nlqo0"]
resource_name = "returnToStartButton"
script/source = "extends Button

var tween
@onready var transitionScreen: ColorRect = $\"../../transitionScreen\"

func onButtonPressed() -> void:
	if tween:
		tween.kill()
	
	tween = create_tween()
	tween.tween_property(transitionScreen, \"modulate:a\", 0, 1).set_ease(Tween.EASE_OUT)
	finished()

func finished() -> void:
	get_tree().change_scene_to_file(\"res://scenes/menus/startMenu/startMenu.tscn\")
"

